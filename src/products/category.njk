---
layout: base.njk
pagination:
  data: productCatalog
  size: 1
  alias: cat
permalink: /products/{{ cat.slug }}/index.html
---

<section class="page-hero product-cat-hero">
  <div class="container">
    <p class="eyebrow"><a href="{{ '/products/' | url }}"
      data-th="← สินค้าทั้งหมด"
      data-en="← All Products">← สินค้าทั้งหมด</a></p>
    <span class="product-hero-icon">{{ cat.th.icon }}</span>
    <h1 data-th="{{ cat.th.title }}" data-en="{{ cat.en.title }}">{{ cat.th.title }}</h1>
    <p class="hero-lead"
      data-th="{{ cat.th.desc }}"
      data-en="{{ cat.en.desc }}">{{ cat.th.desc }}</p>
  </div>
</section>

<section class="section">
  <div class="container">
    <div class="subcat-grid">
      {%- for sub in cat.subcategories %}
      <article class="subcat-card">
        <div class="subcat-card-body">
          <h2 class="subcat-title"
            data-th="{{ sub.th.title }}"
            data-en="{{ sub.en.title }}">{{ sub.th.title }}</h2>
          <p data-th="{{ sub.th.desc }}"
            data-en="{{ sub.en.desc }}">{{ sub.th.desc }}</p>

          {%- if sub.th.models | length %}
          <div class="model-tags">
            {%- for model in sub.th.models %}
            <span class="model-tag">{{ model }}</span>
            {%- endfor %}
          </div>
          {%- endif %}

          <a href="{{ '/' | url }}#contact" class="btn btn-primary"
            data-th="ขอใบเสนอราคา"
            data-en="Request a Quote">ขอใบเสนอราคา</a>
        </div>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- CTA band -->
<section class="section section-dark">
  <div class="container narrow" style="text-align:center">
    <h2 class="section-title"
      data-th="ปรึกษาผู้เชี่ยวชาญ Metro CAT"
      data-en="Talk to a Metro CAT Expert">ปรึกษาผู้เชี่ยวชาญ Metro CAT</h2>
    <p class="section-intro"
      data-th="ทีมงานของเราพร้อมแนะนำสินค้าที่ตรงกับความต้องการของคุณ"
      data-en="Our team is ready to recommend the right machine for your needs.">ทีมงานของเราพร้อมแนะนำสินค้าที่ตรงกับความต้องการของคุณ</p>
    <div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap">
      <a href="tel:{{ site.phone_link }}" class="btn btn-primary btn-lg">☎ {{ site.phone }}</a>
      <a href="{{ '/' | url }}#contact" class="btn btn-outline btn-lg"
        data-th="{{ th.contact.cta }}"
        data-en="{{ en.contact.cta }}">{{ th.contact.cta }}</a>
    </div>
  </div>
</section>
