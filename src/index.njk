---
layout: base.njk
---
{% from "partials/cards.njk" import postCard, promoCard %}

<!-- Hero -->
<section id="home" class="hero{% if not th.hero.image %} no-image{% endif %}"{% if th.hero.image %} style="background-image:url('{{ th.hero.image }}')"{% endif %}>
  <div class="container hero-inner">
    <p class="eyebrow" data-th="{{ th.hero.eyebrow }}" data-en="{{ en.hero.eyebrow }}">{{ th.hero.eyebrow }}</p>
    <h1 data-th="{{ th.hero.title }}" data-en="{{ en.hero.title }}">{{ th.hero.title }}</h1>
    <p class="hero-lead" data-th="{{ th.hero.lead }}" data-en="{{ en.hero.lead }}">{{ th.hero.lead }}</p>
    <div class="hero-actions">
      <a href="#products" class="btn btn-primary" data-th="{{ th.hero.cta_primary }}" data-en="{{ en.hero.cta_primary }}">{{ th.hero.cta_primary }}</a>
      <a href="#contact" class="btn btn-outline" data-th="{{ th.hero.cta_secondary }}" data-en="{{ en.hero.cta_secondary }}">{{ th.hero.cta_secondary }}</a>
    </div>
  </div>
</section>

<!-- Feature boxes -->
<section class="features-band">
  <div class="container feature-grid">
    {%- for f in th.features %}
    <div class="feature-box">
      <span class="feature-icon">{{ f.icon }}</span>
      <div>
        <h3 data-th="{{ f.title }}" data-en="{{ en.features[loop.index0].title }}">{{ f.title }}</h3>
        <p data-th="{{ f.desc }}" data-en="{{ en.features[loop.index0].desc }}">{{ f.desc }}</p>
      </div>
    </div>
    {%- endfor %}
  </div>
</section>

<!-- Stats band -->
<section class="stats-band">
  <div class="container">
    <ul class="hero-stats" aria-label="ข้อมูลสำคัญของบริษัท">
      {%- for stat in th.hero.stats %}
      <li><strong>{{ stat.value }}</strong><span data-th="{{ stat.label }}" data-en="{{ en.hero.stats[loop.index0].label }}">{{ stat.label }}</span></li>
      {%- endfor %}
    </ul>
  </div>
</section>

<!-- Product categories -->
<section id="products" class="section section-alt">
  <div class="container">
    <h2 class="section-title" data-th="{{ th.products.title }}" data-en="{{ en.products.title }}">{{ th.products.title }}</h2>
    <p class="section-intro" data-th="{{ th.products.intro }}" data-en="{{ en.products.intro }}">{{ th.products.intro }}</p>
    <div class="cat-grid">
      {%- for item in th.products.items %}
      <article class="cat-card{% if not item.image %} no-image{% endif %}"{% if item.image %} style="background-image:url('{{ item.image }}')"{% endif %}>
        <div class="cat-card-overlay">
          <h3 data-th="{{ item.title }}" data-en="{{ en.products.items[loop.index0].title }}">{{ item.title }}</h3>
          <p data-th="{{ item.desc }}" data-en="{{ en.products.items[loop.index0].desc }}">{{ item.desc }}</p>
        </div>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Machine lineup (interactive hologram demo) -->
<section id="lineup" class="section">
  <div class="container">
    <h2 class="section-title" data-th="รุ่นเครื่องจักร" data-en="Machine Lineup">รุ่นเครื่องจักร</h2>
    <p class="section-intro" data-th="คลิกที่รุ่นเพื่อดูภาพ — รุ่นที่มีภาพ 360° ลากเพื่อหมุนดูรอบคันได้" data-en="Click a model to preview it — drag to rotate models that have a 360° image set">คลิกที่รุ่นเพื่อดูภาพ — รุ่นที่มีภาพ 360° ลากเพื่อหมุนดูรอบคันได้</p>

    <div class="holo-lineup">
      <!-- Stage: shows the currently selected model -->
      <div class="holo-stage">
        <div class="holo-platform">
          <img class="holo-img" src="{{ '/images/excavator-holo.svg' | url }}" alt="" draggable="false" />
          <span class="holo-scan" aria-hidden="true"></span>
          <span class="holo-glow" aria-hidden="true"></span>
        </div>
        <span class="holo-spin-hint" aria-hidden="true" hidden data-th="ลากเพื่อหมุน 360°" data-en="Drag to rotate 360°">ลากเพื่อหมุน 360°</span>
        <div class="holo-caption">
          <span class="holo-model">301.7 CR</span>
          <span class="holo-sub" data-th="รถขุดตีนตะขาบ Caterpillar" data-en="Caterpillar Hydraulic Excavator">รถขุดตีนตะขาบ Caterpillar</span>
        </div>
      </div>

      <!-- Category + model badges -->
      <div class="holo-models">
        <h3 data-th="รถขุด" data-en="Excavators">รถขุด</h3>
        <p class="holo-models-desc" data-th="รถขุดตีนตะขาบ Caterpillar ครบทุกขนาด ตั้งแต่รถขุดมินิงานแคบ ไปจนถึงรถขุดขนาดใหญ่สำหรับงานโครงการหนัก" data-en="Caterpillar tracked excavators in every size — from compact machines for tight sites to large excavators for heavy projects.">รถขุดตีนตะขาบ Caterpillar ครบทุกขนาด ตั้งแต่รถขุดมินิงานแคบ ไปจนถึงรถขุดขนาดใหญ่สำหรับงานโครงการหนัก</p>
        <div class="model-badges" role="tablist">
          {%- set excavators = ["301.7 CR","305 CR","308 CR","310","313","315","320","323","326","330","336","340","349","352","365","390","395"] %}
          {%- for m in excavators %}
          {%- set media = modelMedia[m] %}
          {%- set badgeImg = '/images/excavator-holo.svg' %}
          {%- if media and media.spin and media.spin.poster %}{% set badgeImg = media.spin.poster %}{% endif %}
          {%- if media and media.image %}{% set badgeImg = media.image %}{% endif %}
          {%- if media and media.model3d and media.model3d.poster %}{% set badgeImg = media.model3d.poster %}{% endif %}
          <button type="button" class="model-badge{{ ' is-active' if loop.first }}" data-model="{{ m }}"
            {%- if media and media.model3d %} data-glb="{{ media.model3d.src | url }}"{% if media.model3d.usdz %} data-usdz="{{ media.model3d.usdz | url }}"{% endif %}{% if media.model3d.ar %} data-ar="1"{% endif %}
            {%- elif media and media.spin %} data-spin-dir="{{ media.spin.dir | url }}" data-spin-count="{{ media.spin.count }}" data-spin-ext="{{ media.spin.ext or 'jpg' }}" data-spin-pad="{{ media.spin.pad if media.spin.pad is defined else 2 }}" data-spin-start="{{ media.spin.start or 1 }}"{% endif %} data-img="{{ badgeImg | url }}" aria-pressed="{{ 'true' if loop.first else 'false' }}">
            <span class="model-badge-label">{{ m }}</span>
            <span class="model-badge-holo" aria-hidden="true">
              <img src="{{ badgeImg | url }}" alt="" />
            </span>
          </button>
          {%- endfor %}
        </div>
        <a href="#contact" class="btn btn-primary" data-th="ขอใบเสนอราคา" data-en="Request a Quote">ขอใบเสนอราคา</a>
      </div>
    </div>
  </div>
</section>

<!-- Promo banner -->
<section class="promo-banner{% if not th.promo_banner.image %} no-image{% endif %}"{% if th.promo_banner.image %} style="background-image:url('{{ th.promo_banner.image }}')"{% endif %}>
  <div class="container promo-banner-inner">
    <p class="eyebrow" data-th="{{ th.promo_banner.eyebrow }}" data-en="{{ en.promo_banner.eyebrow }}">{{ th.promo_banner.eyebrow }}</p>
    <h2 data-th="{{ th.promo_banner.title }}" data-en="{{ en.promo_banner.title }}">{{ th.promo_banner.title }}</h2>
    <p class="promo-banner-text" data-th="{{ th.promo_banner.text }}" data-en="{{ en.promo_banner.text }}">{{ th.promo_banner.text }}</p>
    <a href="{{ th.promo_banner.url | url }}" class="btn btn-primary btn-lg" data-th="{{ th.promo_banner.cta }}" data-en="{{ en.promo_banner.cta }}">{{ th.promo_banner.cta }}</a>
  </div>
</section>

<!-- About -->
<section id="about" class="section">
  <div class="container">
    <h2 class="section-title" data-th="{{ th.about.title }}" data-en="{{ en.about.title }}">{{ th.about.title }}</h2>
    <div class="about-grid">
      <div>
        <p data-th="{{ th.about.p1 }}" data-en="{{ en.about.p1 }}">{{ th.about.p1 }}</p>
        <p data-th="{{ th.about.p2 }}" data-en="{{ en.about.p2 }}">{{ th.about.p2 }}</p>
      </div>
      <div class="about-card">
        <h3 data-th="{{ th.about.promise_title }}" data-en="{{ en.about.promise_title }}">{{ th.about.promise_title }}</h3>
        <ul class="check-list">
          {%- for line in th.about.promise %}
          <li data-th="{{ line }}" data-en="{{ en.about.promise[loop.index0] }}">{{ line }}</li>
          {%- endfor %}
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Services -->
<section id="services" class="section section-alt">
  <div class="container">
    <h2 class="section-title" data-th="{{ th.services.title }}" data-en="{{ en.services.title }}">{{ th.services.title }}</h2>
    <p class="section-intro" data-th="{{ th.services.intro }}" data-en="{{ en.services.intro }}">{{ th.services.intro }}</p>
    <div class="card-grid">
      {%- for item in th.services.items %}
      <article class="card card-accent">
        <h3 data-th="{{ item.title }}" data-en="{{ en.services.items[loop.index0].title }}">{{ item.title }}</h3>
        <p data-th="{{ item.desc }}" data-en="{{ en.services.items[loop.index0].desc }}">{{ item.desc }}</p>
      </article>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Why Us -->
<section id="why" class="section section-dark">
  <div class="container">
    <h2 class="section-title" data-th="{{ th.why.title }}" data-en="{{ en.why.title }}">{{ th.why.title }}</h2>
    <div class="why-grid">
      {%- for item in th.why.items %}
      <div class="why-item">
        <span class="why-num">{{ item.num }}</span>
        <h3 data-th="{{ item.title }}" data-en="{{ en.why.items[loop.index0].title }}">{{ item.title }}</h3>
        <p data-th="{{ item.desc }}" data-en="{{ en.why.items[loop.index0].desc }}">{{ item.desc }}</p>
      </div>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Latest blog posts -->
{% set thPosts = collections.post | byLang("th") | limit(3) %}
{% set enPosts = collections.post | byLang("en") | limit(3) %}
{% if thPosts.length or enPosts.length %}
<section class="section">
  <div class="container">
    <div class="section-head-row">
      <div>
        <h2 class="section-title" data-th="{{ th.blog_section.title }}" data-en="{{ en.blog_section.title }}">{{ th.blog_section.title }}</h2>
        <p class="section-intro" data-th="{{ th.blog_section.intro }}" data-en="{{ en.blog_section.intro }}">{{ th.blog_section.intro }}</p>
      </div>
      <a href="{{ '/blog/' | url }}" class="btn btn-outline-dark" data-th="{{ th.blog_section.view_all }}" data-en="{{ en.blog_section.view_all }}">{{ th.blog_section.view_all }}</a>
    </div>
    <div class="card-grid" data-lang-list>
      {%- for p in thPosts %}{{ postCard(p, th.ui) }}{%- endfor %}
      {%- for p in enPosts %}{{ postCard(p, en.ui) }}{%- endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- Latest promotions -->
{% set thPromos = collections.promo | byLang("th") | limit(3) %}
{% set enPromos = collections.promo | byLang("en") | limit(3) %}
{% if thPromos.length or enPromos.length %}
<section class="section section-alt">
  <div class="container">
    <div class="section-head-row">
      <div>
        <h2 class="section-title" data-th="{{ th.promo_section.title }}" data-en="{{ en.promo_section.title }}">{{ th.promo_section.title }}</h2>
        <p class="section-intro" data-th="{{ th.promo_section.intro }}" data-en="{{ en.promo_section.intro }}">{{ th.promo_section.intro }}</p>
      </div>
      <a href="{{ '/promotions/' | url }}" class="btn btn-outline-dark" data-th="{{ th.promo_section.view_all }}" data-en="{{ en.promo_section.view_all }}">{{ th.promo_section.view_all }}</a>
    </div>
    <div class="card-grid" data-lang-list>
      {%- for p in thPromos %}{{ promoCard(p, th.ui) }}{%- endfor %}
      {%- for p in enPromos %}{{ promoCard(p, en.ui) }}{%- endfor %}
    </div>
  </div>
</section>
{% endif %}

<!-- FAQ -->
<section id="faq" class="section">
  <div class="container narrow">
    <h2 class="section-title" data-th="{{ th.faq.title }}" data-en="{{ en.faq.title }}">{{ th.faq.title }}</h2>
    <div class="faq-list">
      {%- for item in th.faq.items %}
      <details class="faq-item"{{ " open" if loop.first }}>
        <summary data-th="{{ item.q }}" data-en="{{ en.faq.items[loop.index0].q }}">{{ item.q }}</summary>
        <p data-th="{{ item.a }}" data-en="{{ en.faq.items[loop.index0].a }}">{{ item.a }}</p>
      </details>
      {%- endfor %}
    </div>
  </div>
</section>

<!-- Contact / CTA -->
<section id="contact" class="section section-cta">
  <div class="container narrow">
    <h2 class="section-title" data-th="{{ th.contact.title }}" data-en="{{ en.contact.title }}">{{ th.contact.title }}</h2>
    <p class="section-intro" data-th="{{ th.contact.intro }}" data-en="{{ en.contact.intro }}">{{ th.contact.intro }}</p>
    <div class="contact-grid">
      <div class="contact-card">
        <h3 data-th="{{ th.contact.call_label }}" data-en="{{ en.contact.call_label }}">{{ th.contact.call_label }}</h3>
        <p><a href="tel:{{ site.phone_link }}">{{ th.contact.phone }}</a></p>
      </div>
      <div class="contact-card">
        <h3 data-th="{{ th.contact.visit_label }}" data-en="{{ en.contact.visit_label }}">{{ th.contact.visit_label }}</h3>
        <p data-th="{{ th.contact.address }}" data-en="{{ en.contact.address }}">{{ th.contact.address }}</p>
      </div>
      <div class="contact-card">
        <h3 data-th="{{ th.contact.follow_label }}" data-en="{{ en.contact.follow_label }}">{{ th.contact.follow_label }}</h3>
        <p><a href="{{ th.contact.facebook_url }}" rel="noopener">{{ th.contact.facebook_text }}</a></p>
      </div>
    </div>
    <a href="tel:{{ site.phone_link }}" class="btn btn-primary btn-lg" data-th="{{ th.contact.cta }}" data-en="{{ en.contact.cta }}">{{ th.contact.cta }}</a>
  </div>
</section>

<!-- FAQ structured data (AEO) -->
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {%- for item in th.faq.items %}
    {
      "@type": "Question",
      "name": {{ item.q | dump | safe }},
      "acceptedAnswer": { "@type": "Answer", "text": {{ item.a | dump | safe }} }
    }{{ "," if not loop.last }}
    {%- endfor %}
  ]
}
</script>

<!-- Machine lineup: click a badge to swap the stage model; drag to rotate 360° sets -->
<script>
  (function () {
    var stage = document.querySelector(".holo-stage");
    if (!stage) return;
    var stageImg = stage.querySelector(".holo-img");
    var stageModel = stage.querySelector(".holo-model");
    var hint = stage.querySelector(".holo-spin-hint");
    var platform = stage.querySelector(".holo-platform");
    var badges = document.querySelectorAll(".holo-models .model-badge");

    var spin = null;      // teardown handle for the active spin viewer
    var selToken = 0;     // guards async <model-viewer> loads against fast clicks
    var MV_SRC = "https://cdn.jsdelivr.net/npm/@google/model-viewer@4/dist/model-viewer.min.js";

    // Lazy-load the <model-viewer> library once, on first 3D model
    function ensureModelViewer(cb) {
      if (window.customElements && customElements.get("model-viewer")) return cb();
      var existing = document.getElementById("mv-lib");
      if (existing) { existing.addEventListener("load", cb); return; }
      var s = document.createElement("script");
      s.type = "module"; s.id = "mv-lib"; s.src = MV_SRC;
      s.addEventListener("load", cb);
      document.head.appendChild(s);
    }

    function pad(n, len) {
      n = String(n);
      while (n.length < len) n = "0" + n;
      return n;
    }

    // Build the list of frame URLs from a badge's data-spin-* attributes
    function buildFrames(b) {
      var dir = b.getAttribute("data-spin-dir");
      if (!dir) return null;
      var count = parseInt(b.getAttribute("data-spin-count"), 10) || 0;
      if (count < 2) return null;
      var ext = b.getAttribute("data-spin-ext") || "jpg";
      var padLen = parseInt(b.getAttribute("data-spin-pad"), 10);
      if (isNaN(padLen)) padLen = 2;
      var start = parseInt(b.getAttribute("data-spin-start"), 10);
      if (isNaN(start)) start = 1;
      var base = dir.replace(/\/$/, "");
      var frames = [];
      for (var i = 0; i < count; i++) {
        var num = start + i;
        frames.push(base + "/" + (padLen > 0 ? pad(num, padLen) : num) + "." + ext);
      }
      return frames;
    }

    function teardownSpin() {
      if (spin) { spin(); spin = null; }
      stage.classList.remove("is-spin", "is-dragging");
      if (hint) hint.hidden = true;
    }

    function teardown3d() {
      var mv = platform.querySelector(".holo-mv");
      if (mv) mv.remove();
      stage.classList.remove("is-3d");
    }

    function setup3d(badge, token) {
      var src = badge.getAttribute("data-glb");
      ensureModelViewer(function () {
        if (token !== selToken) return; // a newer selection won the race
        teardown3d();
        var mv = document.createElement("model-viewer");
        mv.className = "holo-mv";
        mv.setAttribute("src", src);
        mv.setAttribute("poster", badge.getAttribute("data-img"));
        mv.setAttribute("alt", badge.getAttribute("data-model"));
        mv.setAttribute("camera-controls", "");
        mv.setAttribute("auto-rotate", "");
        mv.setAttribute("touch-action", "pan-y");
        mv.setAttribute("shadow-intensity", "1");
        mv.setAttribute("exposure", "1");
        if (badge.getAttribute("data-usdz")) mv.setAttribute("ios-src", badge.getAttribute("data-usdz"));
        if (badge.getAttribute("data-ar") === "1") { mv.setAttribute("ar", ""); }
        platform.appendChild(mv);
        stage.classList.add("is-3d");
      });
    }

    function setupSpin(frames) {
      frames.forEach(function (src) { var im = new Image(); im.src = src; }); // preload
      var idx = 0;
      var step = 8;          // px of drag per frame change
      var dragging = false, lastX = 0, acc = 0;

      stageImg.src = frames[0];
      stage.classList.add("is-spin");
      if (hint) hint.hidden = false;

      function show(i) {
        i = ((i % frames.length) + frames.length) % frames.length;
        idx = i;
        stageImg.src = frames[i];
      }
      function getX(e) { return e.touches ? e.touches[0].clientX : e.clientX; }
      function down(e) { dragging = true; lastX = getX(e); acc = 0; stage.classList.add("is-dragging"); }
      function move(e) {
        if (!dragging) return;
        var x = getX(e);
        acc += x - lastX; lastX = x;
        while (acc >= step) { show(idx + 1); acc -= step; }
        while (acc <= -step) { show(idx - 1); acc += step; }
        if (e.cancelable) e.preventDefault();
      }
      function up() { dragging = false; stage.classList.remove("is-dragging"); }

      stage.addEventListener("mousedown", down);
      window.addEventListener("mousemove", move);
      window.addEventListener("mouseup", up);
      stage.addEventListener("touchstart", down, { passive: true });
      stage.addEventListener("touchmove", move, { passive: false });
      window.addEventListener("touchend", up);

      spin = function () {
        stage.removeEventListener("mousedown", down);
        window.removeEventListener("mousemove", move);
        window.removeEventListener("mouseup", up);
        stage.removeEventListener("touchstart", down);
        stage.removeEventListener("touchmove", move);
        window.removeEventListener("touchend", up);
      };
    }

    function select(badge) {
      badges.forEach(function (b) {
        b.classList.remove("is-active");
        b.setAttribute("aria-pressed", "false");
      });
      badge.classList.add("is-active");
      badge.setAttribute("aria-pressed", "true");

      selToken++;
      teardownSpin();
      teardown3d();
      stageModel.textContent = badge.getAttribute("data-model");

      if (badge.getAttribute("data-glb")) {
        setup3d(badge, selToken);
        stageImg.src = badge.getAttribute("data-img"); // poster shown until lib loads
      } else {
        var frames = buildFrames(badge);
        if (frames) { setupSpin(frames); }
        else { stageImg.src = badge.getAttribute("data-img"); }
      }

      // Re-trigger the "materialise" animation
      stage.classList.remove("is-swapping");
      void stage.offsetWidth;
      stage.classList.add("is-swapping");
    }

    badges.forEach(function (badge) {
      badge.addEventListener("click", function () { select(badge); });
    });
  })();
</script>
